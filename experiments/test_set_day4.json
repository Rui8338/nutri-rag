        "tool": "search_nutrition_principles",
        "should_have_chunks": true,
        "min_top_score": 0.5
      },
      "tests": ["routing", "retrieval_relevance", "source_diversity"]
    },
    {
      "id": "R4",
      "category": "rag_positive",
