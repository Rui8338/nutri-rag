        "tool": null,
        "should_refuse": true
      },
      "tests": ["routing", "refusal"]
    },
    {
      "id": "D3",
      "category": "refusal",
      "query": "Calcula a minha distribuição de macros.",
      "expected": {
        "tool": null,
        "should_refuse": true
      },
      "tests": ["routing", "refusal"]
    },
    {
      "id": "E1",
      "category": "general",
      "query": "É verdade que comer hidratos à noite faz mal?",
      "expected": {
